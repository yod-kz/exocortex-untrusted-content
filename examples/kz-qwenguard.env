# Example runtime env for using a KZ-hosted QwenGuard endpoint.
# Adjust host, token, and model name for your deployment.

UTC_GUARDRAIL_MODE=openai
UTC_GUARDRAIL_ENDPOINT=http://localhost:8080/v1/chat/completions
UTC_GUARDRAIL_MODEL=qwenguard-7b
UTC_GUARDRAIL_API_KEY=

# Optional: run scanner with the same endpoint/model pattern.
UTC_SCANNER_MODE=heuristic
# UTC_SCANNER_MODE=openai
# UTC_SCANNER_ENDPOINT=http://localhost:8080/v1/chat/completions
# UTC_SCANNER_MODEL=qwenguard-7b
# UTC_SCANNER_API_KEY=
